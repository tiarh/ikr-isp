APP_NAME="IKR ISP"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://ikr.sky.net.id
APP_TIMEZONE=Asia/Jakarta

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=10

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ikr_isp
DB_USERNAME=ikr_isp
DB_PASSWORD=

SALESKIT_DB_HOST=127.0.0.1
SALESKIT_DB_PORT=3306
SALESKIT_DB_DATABASE=skynet_saleskit
SALESKIT_DB_USERNAME=skynet_saleskit
SALESKIT_DB_PASSWORD=

EBILLING_DB_HOST=billing.sky.net.id
EBILLING_DB_PORT=3306
EBILLING_DB_DATABASE=ebilling
EBILLING_DB_USERNAME=ebilling_ro
EBILLING_DB_PASSWORD=

DB_QUEUE_CONNECTION=mysql
DB_QUEUE_TABLE=jobs
DB_QUEUE=default
DB_QUEUE_RETRY_AFTER=90

SALESKIT_API_URL=https://saleskit.sky.net.id/api
SALESKIT_API_KEY=
FIELDOPS_API_URL=https://fieldops.sky.net.id/api
FIELDOPS_API_KEY=
EBILLING_API_URL=https://billing.sky.net.id/api
EBILLING_API_KEY=
EBILLING_TEKNISI_ENDPOINT=/teknisi
EBILLING_COVERAGE_RADIUS_DEFAULT=300

OLT_C300_SSH_HOST=olt-c300.sky.net.id
OLT_C300_SSH_PORT=22
OLT_C300_SSH_USER=admin
OLT_C300_SSH_PASSWORD=
OLT_C300_TIMEOUT=30
OLT_C300_PROMPT_WAIT=3
OLT_C300_VLAN=100

MIKROTIK_API_HOST=mikrotik.sky.net.id
MIKROTIK_API_USER=api_rw
MIKROTIK_API_PASSWORD=
MIKROTIK_API_PORT=8728
MIKROTIK_REST_URL=https://mikrotik.sky.net.id/rest
MIKROTIK_REST_USER=admin
MIKROTIK_REST_PASSWORD=

PPPOE_PREFIX=ikr
PPPOE_PASSWORD_LENGTH=10

EVOLUTION_API_URL=https://evolution.sky.net.id
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=skynet-ikr
EVOLUTION_WA_GROUP_TEKNISI=
EVOLUTION_WA_GROUP_SALES=

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=redis
CACHE_STORE=redis
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.sky.net.id
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

MAIL_MAILER=log
MAIL_FROM_ADDRESS="ikr-no-reply@sky.net.id"
MAIL_FROM_NAME="${APP_NAME}"

CORS_ALLOWED_ORIGINS="https://ikr.sky.net.id"

SANCTUM_STATEFUL_DOMAINS=ikr.sky.net.id

VITE_APP_NAME="${APP_NAME}"
